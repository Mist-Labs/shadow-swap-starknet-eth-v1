# Apibara DNA Token (get from https://apibara.com)
DNA_TOKEN=dna_your_token_here

# PostgreSQL Connection
POSTGRES_CONNECTION_STRING=postgresql://user:password@localhost:5432/shadow-swap-indexer

# ShadowSwap Contract Address (StarkNet Mainnet)
CONTRACT_ADDRESS=0x07576cc5d7cd8f2cf82572a4b7bddeb2eac7de872cdfed575eff399c3ce86114

# Stream URL (Mainnet)
