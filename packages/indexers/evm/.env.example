# Server Configuration
PORT=3000
NODE_ENV=production

# Goldsky Webhook Secret (set in Goldsky dashboard)
GOLDSKY_WEBHOOK_SECRET=your_goldsky_webhook_secret_here

# Webhook URL (your deployed webhook server URL)
WEBHOOK_URL=https://your-webhook-domain.com/webhook

# Relayer Backend URL
RELAYER_BASE_URL=https://your-relayer-domain.com/api/v1

# HMAC Secret (must match backend HMAC_SECRET)
HMAC_SECRET=your_hmac_secret_here
